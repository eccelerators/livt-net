namespace Livt.Net.Tests

using Livt.Net

@Test
component EthernetFrameBuilderTest
{
	builder: EthernetFrameBuilder

	new()
	{
		this.builder = new EthernetFrameBuilder()
	}

	@Test
	fn BuildsReplyEthernetHeader()
	{
		var request: byte[128]
		var clientMac: byte[6]
		clientMac[0] = 0x02
		clientMac[1] = 0x10
		clientMac[2] = 0x20
		clientMac[3] = 0x30
		clientMac[4] = 0x40
		clientMac[5] = 0x50
		var localMac: byte[6]
		localMac[0] = 0x02
		localMac[1] = 0xAA
		localMac[2] = 0xBB
		localMac[3] = 0xCC
		localMac[4] = 0xDD
		localMac[5] = 0xEE
		var etherTypeIpv4: byte[2]
		etherTypeIpv4[0] = 0x08
		etherTypeIpv4[1] = 0x00

		request[6] = clientMac[0]
		request[7] = clientMac[1]
		request[8] = clientMac[2]
		request[9] = clientMac[3]
		request[10] = clientMac[4]
		request[11] = clientMac[5]

		assert this.builder.GetReplyHeaderByte(request, 0, localMac, etherTypeIpv4[0], etherTypeIpv4[1]) == 0x02
		assert this.builder.GetReplyHeaderByte(request, 5, localMac, etherTypeIpv4[0], etherTypeIpv4[1]) == 0x50
		assert this.builder.GetReplyHeaderByte(request, 6, localMac, etherTypeIpv4[0], etherTypeIpv4[1]) == 0x02
		assert this.builder.GetReplyHeaderByte(request, 7, localMac, etherTypeIpv4[0], etherTypeIpv4[1]) == 0xAA
		assert this.builder.GetReplyHeaderByte(request, 11, localMac, etherTypeIpv4[0], etherTypeIpv4[1]) == 0xEE
		assert this.builder.GetReplyHeaderByte(request, 12, localMac, etherTypeIpv4[0], etherTypeIpv4[1]) == 0x08
		assert this.builder.GetReplyHeaderByte(request, 13, localMac, etherTypeIpv4[0], etherTypeIpv4[1]) == 0x00
		assert this.builder.GetReplyHeaderByte(request, 14, localMac, etherTypeIpv4[0], etherTypeIpv4[1]) == 0x00
	}
}
